{
  "name": "@openfort/openfort-node",
  "version": "0.10.6",
  "description": "Openfort Node SDK",
  "author": "Openfort",
  "repository": {
    "type": "git",
    "url": "https://github.com/openfort-xyz/openfort-node.git"
  },
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./*": "./dist/*"
  },
  "typesVersions": {
    "*": {
      "model/*": [
        "dist/model/*"
      ],
      "api/*": [
        "dist/api/*"
      ]
    }
  },
  "typings": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "node -p \"'export const VERSION = \\'' + require('./package.json').version + '\\'\\nexport const PACKAGE = \\'' + require('./package.json').name + '\\''\" > src/version.ts",
    "build": "tsup",
    "preinstall": "npx only-allow pnpm",
    "prepublishOnly": "pnpm install && pnpm build",
    "changeset": "changeset",
    "changeset:version": "pnpm install --lockfile-only && changeset version",
    "changeset:publish": "pnpm build && changeset publish",
    "changeset:prepublish": "pnpm build",
    "check": "biome check --write --unsafe",
    "check:types": "tsc --noEmit",
    "check:exports": "attw --pack . --ignore-rules false-esm",
    "lint": "biome lint",
    "test": "vitest run",
    "test:ci": "vitest run --reporter=verbose",
    "test:cov": "vitest run --coverage",
    "test:build": "publint --strict && attw --pack . --ignore-rules false-esm",
    "orval": "make check-openapi || echo 'NOTE: A newer OpenAPI spec is available. Run pnpm orval:update to update.'; orval --config orval.config.ts",
    "orval:update": "make update-openapi && orval --config orval.config.ts",
    "docs": "typedoc --entryPoints src/index.ts --out docs/ --includes src/**/*.ts",
    "docs:json": "typedoc --entryPoints src/index.ts --includes src/**/*.ts --json docs/spec.json --excludeExternals"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@openfort/shield-js": "^0.1.37",
    "axios": "^1.18.1",
    "axios-retry": "^4.5.0",
    "bs58": "^6.0.0",
    "jose": "^6.2.3",
    "zod": "^3.25.76"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm check"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@biomejs/biome": "^2.5.1",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@solana-program/compute-budget": "^0.16.0",
    "@solana-program/system": "^0.12.2",
    "@solana-program/token": "^0.14.0",
    "@solana/kit": "^7.0.0",
    "@solana/kora": "^0.2.1",
    "@solana/transaction-confirmation": "^7.0.0",
    "@types/node": "^25.9.4",
    "@vitest/coverage-v8": "^4.1.9",
    "knip": "^6.23.0",
    "orval": "^8.19.0",
    "publint": "^0.3.21",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "viem": "^2.54.1",
    "vite": "^8.1.2",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@solana-program/compute-budget": ">=0.7.0",
    "@solana-program/system": ">=0.7.0",
    "@solana-program/token": ">=0.7.0",
    "@solana/kit": ">=6.0.0",
    "@solana/kora": ">=0.1.0",
    "@solana/transaction-confirmation": ">=6.0.0",
    "viem": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "@solana/kit": {
      "optional": true
    },
    "@solana-program/compute-budget": {
      "optional": true
    },
    "@solana-program/system": {
      "optional": true
    },
    "@solana-program/token": {
      "optional": true
    },
    "@solana/kora": {
      "optional": true
    },
    "@solana/transaction-confirmation": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "pnpm": {
    "overrides": {
      "@solana/kora>@solana/kit": "$@solana/kit",
      "@solana/kora>@solana-program/token": "$@solana-program/token",
      "cross-spawn@<6.0.6": ">=6.0.6",
      "cross-spawn@>=7.0.0 <7.0.5": ">=7.0.5",
      "micromatch@<4.0.8": ">=4.0.8",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "smol-toml@<1.6.1": ">=1.6.1",
      "vite@>=6.0.0 <=6.4.1": ">=6.4.2",
      "vite@>=7.0.0 <=7.3.1": ">=7.3.2",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3",
      "axios": "$axios",
      "ws@<8.21.0": ">=8.21.0",
      "esbuild@<0.28.1": ">=0.28.1"
    },
    "onlyBuiltDependencies": [
      "simple-git-hooks",
      "esbuild"
    ]
  },
  "packageManager": "pnpm@10.16.1"
}
