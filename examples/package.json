{
  "name": "@openfort/openfort-node-examples",
  "version": "1.0.0",
  "private": true,
  "description": "Examples for the Openfort Node SDK",
  "type": "module",
  "scripts": {
    "build:sdk": "pnpm --dir .. build",
    "preinstall": "pnpm --dir .. install",
    "setup": "pnpm install && pnpm build:sdk",
    "example": "tsx",
    "format": "biome format --write",
    "lint": "biome lint",
    "check": "biome check --write"
  },
  "keywords": [],
  "author": "Openfort",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.1.6"
  },
  "dependencies": {
    "@openfort/openfort-node": "link:..",
    "@solana-program/compute-budget": "^0.14.0",
    "@solana-program/memo": "^0.11.0",
    "@solana-program/system": "^0.12.0",
    "@solana-program/token": "^0.12.0",
    "@solana/kit": "^6.1.0",
    "@solana/kora": "^0.1.3",
    "@solana/transaction-confirmation": "^6.1.0",
    "@types/express": "^4.17.17",
    "dotenv": "^16.3.1",
    "express": "^4.19.2",
    "viem": "^2.21.0"
  },
  "pnpm": {
    "overrides": {
      "@solana/kora>@solana/kit": "$@solana/kit",
      "@solana/kora>@solana-program/token": "$@solana-program/token"
    }
  }
}
